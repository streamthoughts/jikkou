{
  "type": "object",
  "title": "V1KafkaTopic",
  "description": "KafkaTopic resources provide a way of managing topics in a Kafka cluster.",
  "javaInterfaces": [
    "io.streamthoughts.jikkou.core.models.Resource",
    "io.streamthoughts.jikkou.core.models.HasMetadata",
    "io.streamthoughts.jikkou.core.models.HasSpec<V1KafkaTopicSpec>"
  ],
  "additionalProperties": {
    "lombok-builder": true,
    "lombok-with": true,
    "all-args-constructor": false,
    "spec": {
      "names": {
        "singular": "kafkatopic",
        "plural": "kafkatopics",
        "shortNames": [
          "kt"
        ]
      },
      "verbs": [
        "*"
      ]
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "properties": {
    "apiVersion": {
      "type": "string",
      "default": "kafka.jikkou.io/v1"
    },
    "kind": {
      "type": "string",
      "default": "KafkaTopic"
    },
    "metadata": {
      "$ref": "./Metadata.json"
    },
    "template": {
      "$ref": "./Template.json"
    },
    "spec": {
      "$ref": "#/$defs/V1KafkaTopicSpec"
    },
    "status": {
      "$ref": "#/$defs/V1KafkaTopicStatus"
    }
  },
  "$defs": {
    "V1KafkaTopicStatus": {
      "type": "object",
      "additionalProperties": {
        "lombok-builder": true,
        "lombok-with": true,
        "lombok-setter": true,
        "all-args-constructor": false
      },
      "properties": {
        "partitions": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/$defs/KafkaTopicPartitionInfo"
          }
        }
      }
    },
    "KafkaTopicPartitionInfo": {
      "type": "object",
      "additionalProperties": {
        "all-args-constructor": false
      },
      "properties": {
        "id": {
          "type": "integer",
          "description": "The partition id."
        },
        "leader": {
          "type": "integer",
          "description": "The id of the broker that is the leader for this partition."
        },
        "isr": {
          "type": "array",
          "description": "The list of in-sync replica ids for this partition.",
          "items": {
            "type": "integer"
          }
        },
        "replicas": {
          "type": "array",
          "description": "The list of replica ids for this partition.",
          "items": {
            "type": "integer"
          }
        }
      }
    },
    "V1KafkaTopicSpec": {
      "type": "object",
      "javaInterfaces": [
        "io.streamthoughts.jikkou.core.models.HasConfigRefs"
      ],
      "additionalProperties": {
        "lombok-builder": true,
        "lombok-with": true,
        "lombok-setter": true,
        "all-args-constructor": false
      },
      "properties": {
        "partitions": {
          "type": "integer",
          "description": "The number of partitions for the topic.",
          "default": -1
        },
        "replicas": {
          "type": "object",
          "description": "The number of replicas for the topic.",
          "existingJavaType": "Short",
          "default": -1
        },
        "configs": {
          "existingJavaType": "io.streamthoughts.jikkou.core.models.Configs",
          "description": "The topic configuration properties.",
          "type": "object"
        },
        "configMapRefs": {
          "type": "array",
          "description": "The list of ConfigMap names from which to resolve topic configuration.",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    }
  }
}