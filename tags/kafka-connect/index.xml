&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> topics: &amp;#34;connect-test&amp;#34;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> state: &amp;#34;RUNNING&amp;#34;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> status:
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> connectorStatus:
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> name: &amp;#34;local-file-sink&amp;#34;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> connector:
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> state: &amp;#34;RUNNING&amp;#34;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> workerId: &amp;#34;connect:8083&amp;#34;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> tasks:
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> - id: 0
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> state: &amp;#34;RUNNING&amp;#34;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> workerId: &amp;#34;connect:8083&amp;#34;
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;h3 id="restart-all-connectors-with-a-failed-status-on-all-kafka-connect-clusters">Restart all connectors with a FAILED status on all Kafka Connect clusters.&lt;/h3>
&lt;div class="highlight">&lt;pre tabindex="0" class="chroma">&lt;code class="language-bash" data-lang="bash">&lt;span class="line">&lt;span class="cl">jikkou action kafkaconnectrestartconnectors execute &lt;span class="se">\
&lt;/span>&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="se">&lt;/span>--only-failed
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;h3 id="restart-specific-connector-and-tasks-for-on-kafka-connect-cluster">Restart specific connector and tasks for on Kafka Connect cluster&lt;/h3>
&lt;div class="highlight">&lt;pre tabindex="0" class="chroma">&lt;code class="language-bash" data-lang="bash">&lt;span class="line">&lt;span class="cl">jikkou action kafkaconnectrestartconnectors execute &lt;span class="se">\
&lt;/span>&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="se">&lt;/span>--cluster-name my-connect-cluster
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">--connector-name local-file-sink &lt;span class="se">\
&lt;/span>&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="se">&lt;/span>--include-tasks
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div></description></item></channel></rss>