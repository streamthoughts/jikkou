&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">kind: &amp;#34;ApiActionResultSet&amp;#34;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">apiVersion: &amp;#34;core.jikkou.io/v1&amp;#34;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">metadata:
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> labels: {}
