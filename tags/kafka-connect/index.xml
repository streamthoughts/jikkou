&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">results:
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">- status: &amp;#34;SUCCEEDED&amp;#34;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> data:
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> apiVersion: &amp;#34;kafka.jikkou.io/v1beta1&amp;#34;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> kind: &amp;#34;KafkaConnector&amp;#34;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> metadata:
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> name: &amp;#34;local-file-sink&amp;#34;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> labels:
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> kafka.jikkou.io/connect-cluster: &amp;#34;my-connect-cluster&amp;#34;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> annotations: {}
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> spec:
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> connectorClass: &amp;#34;FileStreamSink&amp;#34;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> tasksMax: 1
