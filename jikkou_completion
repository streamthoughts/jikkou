# Generates completions for the options and subcommands of the `jikkou` command.
function _picocli_jikkou() {
  # Get completion data
  local curr_word=${COMP_WORDS[COMP_CWORD]}
  local prev_word=${COMP_WORDS[COMP_CWORD-1]}

  local commands="create delete update apply patch replace api-extensions api-providers api-resources config diff prepare validate health help generate-completion get action"
  local flag_opts="'-h' '--help' '-V' '--version'"
  local arg_opts="'--logger-level'"

  type compopt &>/dev/null && compopt +o default

  case ${prev_word} in
    '--logger-level')
      return
      ;;
  esac

  if [[ "${curr_word}" == -* ]]; then
    COMPREPLY=( $(compgen -W "${flag_opts} ${arg_opts}" -- "${curr_word}") )
  else
    local positionals=""
    local IFS=$'\n'
    COMPREPLY=( $(compgen -W "${commands// /$'\n'}${IFS}${positionals}" -- "${curr_word}") )
  fi
}

